{
  "name": "@nuitral/theming",
  "version": "0.0.1-beta.2",
  "sass": "dist/scss/_index.scss",
  "style": "dist/nuitral.css",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "media",
    "README.md"
  ],
  "description": "nuitral - theming",
  "author": "Nicola Centonze",
  "license": "MIT",
  "scripts": {
    "format:scss": "prettier 'lib/**/*.scss' --write",
    "stylelint:check": "stylelint 'lib/**/*.scss'",
    "stylelint:fix": "stylelint . --fix",
    "lint": "npm run format:scss && npm run stylelint:fix",
    "build": "rm -rf dist && sass --style=compressed lib/themes/default.scss:dist/nuitral.css && npx ncp lib/scss dist/scss"
  },
  "keywords": [
    "CSS",
    "SCSS",
    "theming",
    "nuitral"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nuitral/theming.git"
  },
  "homepage": "https://github.com/nuitral/theming#readme",
  "devDependencies": {
    "ncp": "^2.0.0",
    "prettier": "^3.8.1",
    "sass": "^1.89.1",
    "stylelint": "^16.26.1",
    "stylelint-config-prettier-scss": "^1.0.0",
    "stylelint-config-standard-scss": "^16.0.0",
    "stylelint-order": "^8.1.1",
    "stylelint-scss": "^6.13.0"
  }
}
